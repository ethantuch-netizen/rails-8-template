<h1>
  Audio test
</h1>

<hr>

<article>
  <header>
    <h2>
      Play two audio files in sequence
    </h2>
  </header>

  <p>
    Press the button once to play both audio files back to back.
  </p>

  <button id="play_sequence_button">Play audio sequence</button>

  <p id="audio_status"></p>
</article>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var playButton = document.getElementById("play_sequence_button")
    var statusText = document.getElementById("audio_status")
    var player = new Audio()

    var audioFiles = [
      "/audio/Q1.m4a",
      "/audio/Q2.m4a"
    ]

    var currentIndex = 0

    function playCurrentAudio() {
      if (currentIndex >= audioFiles.length) {
        statusText.textContent = "Finished playing both files."
        playButton.disabled = false
        return
      }

      player.src = audioFiles[currentIndex]
      statusText.textContent = "Now playing file " + (currentIndex + 1)
      player.play()
    }

    player.addEventListener("ended", function() {
      currentIndex = currentIndex + 1
      playCurrentAudio()
    })

    playButton.addEventListener("click", function() {
      currentIndex = 0
      playButton.disabled = true
      playCurrentAudio()
    })
  })
</script>
