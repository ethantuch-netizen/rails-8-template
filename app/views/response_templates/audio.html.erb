<h1>
  Audio Flashcards
</h1>

<hr>

<article>
  <header>
    <h2>
      Play selected audio files
    </h2>
  </header>

  <p>
    Click once to play the selected audio files back to back.
  </p>

  <button id="play_sequence_button">Play selected audio</button>

  <p id="audio_status"></p>
</article>

<p>
  Selected audio files:
</p>

<ul>
  <% @selected_questions.each do |a_question| %>
    <li><%= a_question.audio_content_and_answer %></li>
  <% end %>
</ul>


<script>
  document.addEventListener("DOMContentLoaded", function() {
    var playButton = document.getElementById("play_sequence_button")
    var statusText = document.getElementById("audio_status")
    var player = new Audio()

    var audioFiles = [
      <% @selected_questions.each_with_index do |a_question, index| %>
        "<%= a_question.audio_content_and_answer %>"<%= "," unless index == @selected_questions.length - 1 %>
      <% end %>
    ]

    console.log(audioFiles)

    var currentIndex = 0

    function playCurrentAudio() {
      if (currentIndex >= audioFiles.length) {
        statusText.textContent = "Finished playing all selected audio files."
        playButton.disabled = false
        return
      }

      player.src = audioFiles[currentIndex]
      statusText.textContent = "Now playing: " + audioFiles[currentIndex]
      player.play()
    }

    player.addEventListener("ended", function() {
      currentIndex = currentIndex + 1
      playCurrentAudio()
    })

    playButton.addEventListener("click", function() {
      if (audioFiles.length === 0) {
        statusText.textContent = "No audio files were selected."
        return
      }

      currentIndex = 0
      playButton.disabled = true
      playCurrentAudio()
    })
  })
</script>
