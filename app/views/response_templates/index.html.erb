<h1>
  List of all responses
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new response
    </h2>
  </header>

  <form action="/insert_response" method="post">
    <div>
      <label for="user_id_box">
        User
      </label>

      <input type="text" id="user_id_box" name="query_user_id">
    </div>

    <div>
      <label for="question_id_box">
        Question
      </label>

      <input type="text" id="question_id_box" name="query_question_id">
    </div>

    <div>
      <label for="correct_result_box">
        Correct result
      </label>

      <input type="text" id="correct_result_box" name="query_correct_result">
    </div>

    <button type="submit">
      Create response
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_responses.each do |a_response| %>
      <li>
        <a href="/responses/<%= a_response.id %>">
          Response #<%= a_response.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
